                <td><span class="status-pill status-planejado">Planejado</span></td>
                <td><span class="priority-tag p-media">Média</span></td>
              </tr>
              <tr>
                <td><input type="checkbox" class="task-check" onchange="updateProgress()"></td>
                <td>Apresentar resultado final ao time LR</td>
                <td>A definir</td>
                <td>30/05</td>
                <td><span class="status-pill status-planejado">Planejado</span></td>
                <td><span class="priority-tag p-baixa">Baixa</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Tab: Termômetro -->
        <div class="tab-content" id="proj-ai-1-termometro">
          <div class="termometro-grande">
            <div class="term-number">65<small>%</small></div>
